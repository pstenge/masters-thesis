@article{2025MarlboroughVineyard,
  title = {2025 {{Marlborough Vineyard Monitoring Report}}},
  abstract = {The 2024/25 season delivered improved profits over the poor 2023/24 season for most Marlborough grape growers. Higher average yields offset lower prices for several varieties, including Sauvignon Blanc, and vineyard expenses were held steady through growers implementing cost-saving measures. {$\bullet$} Grape production in Marlborough for the 2025 vintage was assisted by relatively warm weather during flower initiation in November and December 2023, an excellent flowering period in spring 2024, a dry summer with only short periods of irrigation restrictions, and settled weather over harvest. These conditions resulted in above average bunch numbers, high berry numbers, and close to average berry weights with very high potential yields across the region. {$\bullet$} Disease pressure was low during the dry summer, and grapes were able to be harvested in very good condition. {$\bullet$} Slow market demand and high stock levels from previous vintages meant that wineries strictly enforced yield caps. Around 17 percent of the total producing area in the Marlborough vineyard monitoring programme's survey was unharvested due to reaching contracted tonnages. This is reflected in the yield data reported by the vineyard model. {$\bullet$} The Marlborough vineyard model had an average harvested yield of 14.6 tonnes per producing hectare, up 37 percent on the prior year. Sauvignon Blanc yield was 15.6 tonnes per producing hectare, up 38 percent on the 2024 vintage, and by 14 and 11 percent compared with the 5-year and 10-year average, respectively. Higher yields were also achieved in 2024/25 for the other grape varieties in the vineyard model. {$\bullet$} The average grape price per tonne for the vineyard model decreased \$285 (down 13 percent) to \$1,925, driven by lower grape prices for Sauvignon Blanc and Pinot Gris, and is similar to the average grape price for the model in 2018. {$\bullet$} Grape revenue for the Marlborough vineyard model in 2024/25 was \$28,070 per producing hectare, up 19 percent on 2023/24. {$\bullet$} Due to cost-saving initiatives undertaken by growers, vineyard operating expenses held steady following a run of significant annual increases since vintage 2020. Growers managed to restrain increases in labour expenditure, and purposefully selected cheaper pest and disease products and spent less on fertiliser, with the aim of reducing overall vineyard expenditure. {$\bullet$} The vineyard model's economic vineyard surplus in 2024/25 was \$9,260 per producing hectare, almost double that of the poor financial result in 2023/24. Whilst the operating profit for the model improved in 2024/25, it is below the 5-year and 10-year average economic vineyard surplus for the model by 21 percent and 20 percent, respectively. {$\bullet$} Morale amongst the survey grower group is the lowest it has been for many years, with many worried about market conditions in the short-term. Growers are concerned about declining vineyard values, and potential yield cap reductions and/or lower grape prices further eroding profitability. {$\bullet$} Growers are responding to the challenging market conditions by reducing expenditure on inputs where possible, deferring non-essential repairs and maintenance, and removing unprofitable vineyard blocks which may be replanted or left fallow for the time being.},
  langid = {english}
}

@article{aguiarLocalizationMappingAgriculture2022,
  title = {Localization and {{Mapping}} on {{Agriculture Based}} on {{Point-Feature Extraction}} and {{Semiplanes Segmentation From 3D LiDAR Data}}},
  author = {Aguiar, Andr{\'e} Silva and {Neves dos Santos}, Filipe and Sobreira, H{\'e}ber and {Boaventura-Cunha}, Jos{\'e} and Sousa, Armando Jorge},
  year = 2022,
  month = jan,
  journal = {Front. Robot. AI},
  volume = {9},
  publisher = {Frontiers},
  issn = {2296-9144},
  doi = {10.3389/frobt.2022.832165},
  urldate = {2026-02-24},
  abstract = {Developing ground robots for agriculture is a demanding task. Robots should be capable of performing tasks like spraying, harvesting, or monitoring. However, the absence of structure in the agricultural scenes challenges the implementation of localization and mapping algorithms. Thus, the research and development of localization techniques are essential to boost agricultural robotics. To address this issue, we propose an algorithm called VineSLAM suitable for localization and mapping in agriculture. This approach uses both point- and semiplane-features extracted from 3D LiDAR data to map the environment and localize the robot using a novel Particle Filter that considers both feature modalities. The numeric stability of the algorithm was tested using simulated data.The proposed methodology proved to be suitable to localize a robot using only three orthogonal semiplanes. Moreover, the entire VineSLAM pipeline was compared against a state-of-the-art approach considering three real-world experiments in a woody-crop vineyard. Results show that our approach can localize the robot with precision even in long and symmetric vineyard corridors outperforming the state-of-the-art algorithm in this context.},
  langid = {english},
  keywords = {3D LIDAR,Agriculture,localization,Mapping,Semiplanes}
}

@misc{ahmedMachineVisionBasedCropLoad2023,
  title = {Machine {{Vision-Based Crop-Load Estimation Using YOLOv8}}},
  author = {Ahmed, Dawood and Sapkota, Ranjan and Churuvija, Martin and Karkee, Manoj},
  year = 2023,
  month = apr,
  number = {arXiv:2304.13282},
  eprint = {2304.13282},
  primaryclass = {cs},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2304.13282},
  urldate = {2026-02-25},
  abstract = {Labor shortages in fruit crop production have prompted the development of mechanized and automated machines as alternatives to labor-intensive orchard operations such as harvesting, pruning, and thinning. Agricultural robots capable of identifying tree canopy parts and estimating geometric and topological parameters, such as branch diameter, length, and angles, can optimize crop yields through automated pruning and thinning platforms. In this study, we proposed a machine vision system to estimate canopy parameters in apple orchards and determine an optimal number of fruit for individual branches, providing a foundation for robotic pruning, flower thinning, and fruitlet thinning to achieve desired yield and quality.Using color and depth information from an RGB-D sensor (Microsoft Azure Kinect DK), a YOLOv8-based instance segmentation technique was developed to identify trunks and branches of apple trees during the dormant season. Principal Component Analysis was applied to estimate branch diameter (used to calculate limb cross-sectional area, or LCSA) and orientation. The estimated branch diameter was utilized to calculate LCSA, which served as an input for crop-load estimation, with larger LCSA values indicating a higher potential fruit-bearing capacity.RMSE for branch diameter estimation was 2.08 mm, and for crop-load estimation, 3.95. Based on commercial apple orchard management practices, the target crop-load (number of fruit) for each segmented branch was estimated with a mean absolute error (MAE) of 2.99 (ground truth crop-load was 6 apples per LCSA). This study demonstrated a promising workflow with high performance in identifying trunks and branches of apple trees in dynamic commercial orchard environments and integrating farm management practices into automated decision-making.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Robotics},
  file = {C:\Users\phili\Zotero\storage\9D2BLNZV\2304.html}
}

